# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Your Sanity project ID (found in sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Sanity dataset (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Sanity API token for draft previews (read-only is enough)
SANITY_API_TOKEN=your_sanity_api_token_here

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# API key from resend.com — required for the contact form to send emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Destination address for contact form submissions
CONTACT_EMAIL=contact@aurespedia.dz

# ── Site URL ───────────────────────────────────────────────────────────────────
# Used for sitemap.xml and OpenGraph metadata — no trailing slash
NEXT_PUBLIC_SITE_URL=https://aurespedia.univ-batna2.dz
